VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# (Tuỳ chọn) Mật khẩu database — script tự tạo bảng, KHÔNG cần vào SQL Editor
# Lấy tại: Supabase project → Settings → Database → Database password
SUPABASE_DB_PASSWORD=your-database-password

# Hoặc full connection string:
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres

# Không có password? App vẫn chạy bình thường, lưu trên trình duyệt (localStorage).
